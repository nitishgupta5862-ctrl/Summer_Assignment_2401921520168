abstract class Compartment {
    public abstract String notice();
}

class FirstClass extends Compartment {
    public String notice() {
        return "First Class: Welcome to First Class Coach";
    }
}

class Ladies extends Compartment {
    public String notice() {
        return "Ladies Coach: Reserved for Ladies";
    }
}

class General extends Compartment {
    public String notice() {
        return "General Coach: Please maintain discipline";
    }
}

class Luggage extends Compartment {
    public String notice() {
        return "Luggage Coach: Goods and luggage only";
    }
}

public class TestCompartment {
    public static void main(String[] args) {

        Compartment[] c = new Compartment[10];

        for (int i = 0; i < 10; i++) {

            int n = (int)(Math.random() * 4) + 1;

            switch (n) {
                case 1:
                    c[i] = new FirstClass();
                    break;

                case 2:
                    c[i] = new Ladies();
                    break;

                case 3:
                    c[i] = new General();
                    break;

                case 4:
                    c[i] = new Luggage();
                    break;
            }
        }

        System.out.println("Notices:");

        for (int i = 0; i < 10; i++) {
            System.out.println(c[i].notice());
        }
    }
}
