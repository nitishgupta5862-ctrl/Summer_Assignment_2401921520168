package live;

import music.Playable;
import music.string.Veena;
import music.wind.Saxophone;

public class Test {
    public static void main(String[] args) {

        // a. Create an instance of Veena and call play()
        System.out.println("--- Veena Instance ---");
        Veena veena = new Veena();
        veena.play();

        // b. Create an instance of Saxophone and call play()
        System.out.println("\n--- Saxophone Instance ---");
        Saxophone saxophone = new Saxophone();
        saxophone.play();

        // c. Place instances in a Playable variable and call play()
        System.out.println("\n--- Using Playable Interface Reference ---");
        Playable playable1 = new Veena();
        playable1.play();

        Playable playable2 = new Saxophone();
        playable2.play();
    }
}
